# Falisha Agent Finder — env vars
# Generate the password hash via: npm run hash-password -- 'your-strong-password'
ADMIN_PASSWORD_HASH=
# 32+ chars of entropy. Generate via: openssl rand -hex 32
ADMIN_SESSION_SECRET=
SESSION_COOKIE_NAME=faf_session
SESSION_TTL_SECONDS=604800

# Supabase (filled in Phase 3c)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Master key for AES-256-GCM encryption of API-key settings (Phase 3c)
# Generate via: openssl rand -base64 32
APP_SETTINGS_MASTER_KEY=

# CORS: comma-separated origins; leave blank in production to allow same-origin only
CORS_ALLOWED_ORIGINS=
